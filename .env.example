# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# For Render: Use the PostgreSQL database connection string provided
# For Local Development: Use default PostgreSQL credentials
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/election_guide
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=election_guide

# ============================================================================
# GOOGLE GEMINI AI CONFIGURATION
# ============================================================================
# For Render: Set these environment variables in Render dashboard
# AI_INTEGRATIONS_* variables are provided by Replit AI Integrations proxy
AI_INTEGRATIONS_GEMINI_BASE_URL=https://your-gemini-proxy.example.com
AI_INTEGRATIONS_GEMINI_API_KEY=replace-with-your-api-key

# ============================================================================
# APPLICATION RUNTIME CONFIGURATION
# ============================================================================
# Session secret for secure session management
SESSION_SECRET=replace-with-a-long-random-secret

# Server port (Render auto-assigns, but can override)
PORT=8080

# Base path for the application
BASE_PATH=/

# Environment (development, production, test)
NODE_ENV=development

# ============================================================================
# FRONTEND CONFIGURATION (Render)
# ============================================================================
# API URL for the frontend to communicate with backend
VITE_API_URL=http://localhost:8080/api

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================
# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# DEPLOYMENT INSTRUCTIONS FOR RENDER
# ============================================================================
# 1. Create a new Web Service on Render.com
# 2. Connect your GitHub repository
# 3. Set Environment Variables:
#    - Copy all values from this file (except comments)
#    - For DATABASE_URL: Render will auto-provision PostgreSQL
#    - For GEMINI_API_KEY: Set your actual Google Gemini API key
#    - For SESSION_SECRET: Generate a random 32+ character string
# 4. Build Command: pnpm install && pnpm run build
# 5. Start Command: pnpm --filter @workspace/api-server run start
# 6. Attach PostgreSQL database from Render dashboard
# ============================================================================
